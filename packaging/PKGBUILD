pkgname=snx
pkgver=0.1.0
pkgrel=1
pkgdesc="Snippet Executor — quickly invoke personal scripts from a central directory"
arch=('x86_64' 'aarch64')
url="https://github.com/LightJack05/snx"
license=('MIT')
makedepends=('go')
source=("$pkgname-$pkgver.tar.gz::https://github.com/LightJack05/$pkgname/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$pkgname-$pkgver"
    export CGO_ENABLED=0
    go build -trimpath -ldflags="-s -w -X main.version=$pkgver" -o snx .
}

package() {
    cd "$pkgname-$pkgver"
    install -Dm755 snx "$pkgdir/usr/bin/snx"
    install -Dm644 completions/snx.zsh "$pkgdir/usr/share/zsh/site-functions/_snx"
    install -Dm644 completions/snx.bash "$pkgdir/usr/share/bash-completion/completions/snx"
    install -Dm644 config.example.toml "$pkgdir/usr/share/doc/snx/config.example.toml"
    install -Dm644 README.md "$pkgdir/usr/share/doc/snx/README.md"
}
